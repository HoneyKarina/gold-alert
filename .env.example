# Gold Alert 配置

# 通知渠道: console | feishu | email | webhook
NOTIFY_CHANNEL=feishu

# 飞书用户 ID（用于私聊通知）
FEISHU_USER_ID=your_feishu_user_id

# 飞书 Webhook（可选，用于群通知）
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 检查间隔（分钟）
CHECK_INTERVAL=60

# 预警阈值（美元）
ALERT_THRESHOLD=30

# 预警阈值（百分比）
ALERT_THRESHOLD_PERCENT=0.7
